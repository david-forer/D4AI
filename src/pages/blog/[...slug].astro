---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SimpleContainer from '../../components/SimpleContainer.astro';
import Seo from '../../components/Seo.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import AuthorBox from '../../components/AuthorBox.astro';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the blog post data
const { entry } = Astro.props as { entry: CollectionEntry<'blog'> };
const { Content, headings } = await entry.render();

// JSON-LD structured data
const siteUrl = "https://davidjforer.com";
const postUrl = `${siteUrl}/blog/${entry.slug}`;
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.description,
  "url": postUrl,
  "datePublished": new Date(entry.data.pubDate).toISOString(),
  ...(entry.data.updatedDate ? { "dateModified": new Date(entry.data.updatedDate).toISOString() } : {}),
  "image": entry.data.heroImage ? `${siteUrl}${entry.data.heroImage}` : `${siteUrl}/images/ai-automation.webp`,
  "author": {
    "@type": "Person",
    "name": "David Forer",
    "url": `${siteUrl}/about`,
    "sameAs": [
      "https://www.linkedin.com/in/davidforer/",
      "https://github.com/david-forer"
    ]
  },
  "publisher": {
    "@type": "Person",
    "name": "David Forer",
    "url": siteUrl
  }
});

// Format the publication date
const formattedDate = new Date(entry.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Define categories for the navigation
const categories = [
  { name: "AI Operations", slug: "ai-operations" },
  { name: "Workflow Systems", slug: "workflow-systems" },
  { name: "AI Automation", slug: "automation" },
  { name: "AI Training", slug: "ai-training" },
  { name: "AI Readiness", slug: "ai-readiness" },
  { name: "SEO + AI", slug: "seo" },
  { name: "AI for Business", slug: "ai-for-business" },
];
---

<Fragment>
  <script is:inline type="application/ld+json" set:html={jsonLd} />
</Fragment>

<Layout
  title={entry.data.seoTitle || entry.data.title}
  description={entry.data.description}
  image={entry.data.heroImage || entry.data.image}
  type="article"
>
  <Seo 
    title={entry.data.seoTitle || entry.data.title}
    description={entry.data.description}
    image={entry.data.heroImage || entry.data.image || "/images/ai-automation.webp"}
    type="article"
  />
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-blue-600 to-blue-800 py-12">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="flex flex-col justify-center">
          <div class="max-w-3xl mx-auto text-center">
            <a href="/blog" class="text-blue-200 hover:text-white mb-6 inline-flex items-center text-sm tracking-wide opacity-75">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
              </svg>
              Back to Blog
            </a>
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{entry.data.title}</h1>
            <p class="text-blue-100">
              Published on {formattedDate}
              {entry.data.updatedDate && (
                <span> � Updated on {new Date(entry.data.updatedDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}</span>
              )}
            </p>
            
            {entry.data.tags && (
              <div class="mt-4 flex flex-wrap gap-2 justify-center">
                {entry.data.tags.map((tag) => {
                  // Find if this tag matches one of our defined categories
                  const matchedCategory = categories.find(cat =>
                    cat.slug === tag.toLowerCase() ||
                    cat.name.toLowerCase() === tag.toLowerCase()
                  );
                  
                  if (!matchedCategory) return null;
                  return (
                    <a
                      href={`/blog/category/${matchedCategory.slug}`}
                      class="px-2 py-1 bg-blue-500 bg-opacity-30 text-white text-xs rounded-full hover:bg-blue-500 hover:bg-opacity-40 transition-colors"
                    >
                      {matchedCategory.name}
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {entry.data.heroImage && (
      <div class="max-w-[1272px] mx-auto px-6 pt-10">
        <img
          src={entry.data.heroImage}
          alt={entry.data.title}
          class="w-full h-auto rounded-lg mb-8 shadow-md"
        />
      </div>
    )}

    <SimpleContainer>
      <div class="pb-12 max-w-6xl mx-auto">

        <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-12">
          <!-- TOC: sticky sidebar on desktop, inline box on mobile -->
          <aside class="mb-8 lg:mb-0">
            <div class="lg:sticky lg:top-8">
              <TableOfContents headings={headings} />
            </div>
          </aside>

          <!-- Article content -->
          <article>
            <div class="prose prose-lg max-w-none">
              <Content />
            </div>
            <AuthorBox />
          </article>
        </div>
      </div>
    </SimpleContainer>
  </main>
</Layout>

<style is:global>
  /* Blog post prose styling */
  .prose h1 {
    font-size: 2.25rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #1d4ed8;
  }

  .prose h2 {
    font-size: 1.75rem;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: #1d4ed8;
  }

  /* Zero out top margin on the very first heading so there's no gap below the hero image */
  .prose h2:first-of-type,
  .prose h1:first-of-type {
    margin-top: 0 !important;
  }

  .prose h3 {
    font-size: 1.5rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #1d4ed8;
  }

  .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .prose ul, .prose ol {
    margin-left: 2rem;
    margin-bottom: 1.25rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose a {
    color: #2563eb;
    text-decoration: underline;
  }

  .prose blockquote {
    border-left: 4px solid #3b82f6;
    padding-left: 1rem;
    font-style: italic;
    margin-left: 0;
    margin-right: 0;
    color: #4b5563;
  }

  .prose img {
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  @media (min-width: 768px) {
    .prose img {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
